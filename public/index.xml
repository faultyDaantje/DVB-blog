    <item>
      <title>Project Gallery</title>
      <link>http://localhost:1313/gallery/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/gallery/</guid>
      <description>&lt;p&gt;Welcome to the DVB Engineering Lab gallery.&lt;/p&gt;&#xA;&lt;style&gt;&#xD;&#xA;  .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 15px; }&#xD;&#xA;  .gallery-item img { width: 100%; height: 250px; object-fit: cover; border-radius: 8px; cursor: pointer; transition: 0.2s; }&#xD;&#xA;  .gallery-item img:hover { filter: brightness(1.1); }&#xD;&#xA;  &#xD;&#xA;  #gallery-overlay {&#xD;&#xA;    display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%;&#xD;&#xA;    background-color: rgba(0,0,0,0.95); align-items: center; justify-content: center;&#xD;&#xA;  }&#xD;&#xA;  #gallery-overlay img { max-width: 90%; max-height: 90%; border-radius: 4px; transition: transform 0.1s ease-out; }&#xD;&#xA;  &#xD;&#xA;  .nav-hint { position: absolute; bottom: 20px; color: #666; font-family: monospace; font-size: 12px; }&#xD;&#xA;&lt;/style&gt;&#xD;&#xA;&#xD;&#xA;&lt;div class=&#34;gallery-grid&#34;&gt;&#xD;&#xA;  &#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2015.27.06%20%282%29.jpeg&#34; onclick=&#34;openLightbox( 0 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2015.27.06%20%281%29.jpeg&#34; onclick=&#34;openLightbox( 1 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2014.51.11.jpeg&#34; onclick=&#34;openLightbox( 2 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2014.51.10.jpeg&#34; onclick=&#34;openLightbox( 3 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2014.51.10%20%282%29.jpeg&#34; onclick=&#34;openLightbox( 4 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2014.51.10%20%281%29.jpeg&#34; onclick=&#34;openLightbox( 5 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2014.49.55.jpeg&#34; onclick=&#34;openLightbox( 6 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2014.49.53.jpeg&#34; onclick=&#34;openLightbox( 7 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/WhatsApp%20Image%202026-04-29%20at%2014.49.53%20%281%29.jpeg&#34; onclick=&#34;openLightbox( 8 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/Screenshot%202026-04-02%20153812.png&#34; onclick=&#34;openLightbox( 9 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/Screenshot%202026-03-12%20140623.png&#34; onclick=&#34;openLightbox( 10 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/Printer.jpg&#34; onclick=&#34;openLightbox( 11 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/IMG-20260414-WA0013.jpg&#34; onclick=&#34;openLightbox( 12 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/avatar.jpg&#34; onclick=&#34;openLightbox( 13 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/20260416_161258.jpg&#34; onclick=&#34;openLightbox( 14 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;    &lt;div class=&#34;gallery-item&#34;&gt;&#xD;&#xA;      &lt;img src=&#34;http://localhost:1313/gallery/20260414_154713.jpg&#34; onclick=&#34;openLightbox( 15 )&#34; alt=&#34;Project Image&#34; class=&#34;lab-img&#34;&gt;&#xD;&#xA;    &lt;/div&gt;&#xD;&#xA;  &#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;div id=&#34;gallery-overlay&#34; onclick=&#34;closeLightbox(event)&#34;&gt;&#xD;&#xA;  &lt;img id=&#34;overlay-img&#34; src=&#34;&#34;&gt;&#xD;&#xA;  &lt;div class=&#34;nav-hint&#34;&gt;USE ARROWS TO NAVIGATE • SCROLL TO ZOOM • ESC TO CLOSE&lt;/div&gt;&#xD;&#xA;&lt;/div&gt;&#xD;&#xA;&#xD;&#xA;&lt;script&gt;&#xD;&#xA;  let currentIndex = 0;&#xD;&#xA;  const images = Array.from(document.querySelectorAll(&#39;.lab-img&#39;)).map(img =&gt; img.src);&#xD;&#xA;  const overlay = document.getElementById(&#39;gallery-overlay&#39;);&#xD;&#xA;  const overlayImg = document.getElementById(&#39;overlay-img&#39;);&#xD;&#xA;  let zoomLevel = 1;&#xD;&#xA;&#xD;&#xA;  function openLightbox(index) {&#xD;&#xA;    currentIndex = index;&#xD;&#xA;    zoomLevel = 1; &#xD;&#xA;    updateImage();&#xD;&#xA;    overlay.style.display = &#39;flex&#39;;&#xD;&#xA;    document.body.style.overflow = &#39;hidden&#39;; &#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  function closeLightbox(event) {&#xD;&#xA;    &#xD;&#xA;    if (event.target === overlay) {&#xD;&#xA;      overlay.style.display = &#39;none&#39;;&#xD;&#xA;      document.body.style.overflow = &#39;auto&#39;;&#xD;&#xA;    }&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  function updateImage() {&#xD;&#xA;    overlayImg.src = images[currentIndex];&#xD;&#xA;    overlayImg.style.transform = `scale(${zoomLevel})`;&#xD;&#xA;  }&#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;  document.addEventListener(&#39;keydown&#39;, (e) =&gt; {&#xD;&#xA;    if (overlay.style.display === &#39;flex&#39;) {&#xD;&#xA;      if (e.key === &#34;ArrowRight&#34;) {&#xD;&#xA;        currentIndex = (currentIndex + 1) % images.length;&#xD;&#xA;        zoomLevel = 1;&#xD;&#xA;        updateImage();&#xD;&#xA;      } else if (e.key === &#34;ArrowLeft&#34;) {&#xD;&#xA;        currentIndex = (currentIndex - 1 + images.length) % images.length;&#xD;&#xA;        zoomLevel = 1;&#xD;&#xA;        updateImage();&#xD;&#xA;      } else if (e.key === &#34;Escape&#34;) {&#xD;&#xA;        overlay.style.display = &#39;none&#39;;&#xD;&#xA;        document.body.style.overflow = &#39;auto&#39;;&#xD;&#xA;      }&#xD;&#xA;    }&#xD;&#xA;  });&#xD;&#xA;&#xD;&#xA;  &#xD;&#xA;  overlay.addEventListener(&#39;wheel&#39;, (e) =&gt; {&#xD;&#xA;    if (overlay.style.display === &#39;flex&#39;) {&#xD;&#xA;      e.preventDefault();&#xD;&#xA;      const delta = e.deltaY * -0.001;&#xD;&#xA;      zoomLevel = Math.min(Math.max(0.5, zoomLevel + delta), 3); &#xD;&#xA;      overlayImg.style.transform = `scale(${zoomLevel})`;&#xD;&#xA;    }&#xD;&#xA;  }, { passive: false });&#xD;&#xA;&lt;/script&gt;</description>
    </item>
